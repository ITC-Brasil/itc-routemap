rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regra atual: qualquer usuário autenticado lê e escreve.
    // TODO Fase 6.1: refinar por coleção com roles admin/operador/visualizador.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
