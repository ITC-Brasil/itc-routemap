# ITC RouteMap — Variáveis de Ambiente
#
# Copie este arquivo para .env.local e preencha os valores reais.
# O .env.local NUNCA deve ser commitado (já está no .gitignore).
# As mesmas variáveis devem estar configuradas na Vercel (Settings > Environment Variables).

# ==============================================================================
# FIREBASE (cliente — expostas ao browser via NEXT_PUBLIC_*)
# Obtidas em: Firebase Console > Configurações do projeto > Seus aplicativos
# ==============================================================================

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ==============================================================================
# FIREBASE ADMIN SDK (servidor — nunca exposta ao browser)
# Service account JSON convertido para Base64:
#   cat service-account.json | base64 -w 0
# ==============================================================================

GOOGLE_SERVICE_ACCOUNT_BASE64=

# ==============================================================================
# GOOGLE MAPS (cliente — exposta ao browser, deve ter restrição de domínio HTTP
# no Google Cloud Console: localhost:3000/*, *.vercel.app/*)
# ==============================================================================

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ==============================================================================
# GOOGLE MAPS (servidor — chave separada com restrição de IP, não HTTP referrer)
# ==============================================================================

GOOGLE_MAPS_SERVER_API_KEY=

# ==============================================================================
# GOOGLE SERVICE ACCOUNT (informativo — e-mail da conta de serviço)
# Exibido na tela de sincronização para guiar o usuário a compartilhar a planilha
# ==============================================================================

NEXT_PUBLIC_SERVICE_ACCOUNT_EMAIL=

# ==============================================================================
# GEMINI (servidor — Google AI Studio)
# Obter em: https://aistudio.google.com/app/apikey
# Definir GEMINI_ENABLED=false para usar o modo fallback sem IA
# ==============================================================================

GEMINI_API_KEY=
GEMINI_ENABLED=true
